# build outputs
/dist/
/dist-nuitka/
# ignore ALL work-dirs under build/ (PyInstaller/Nuitka intermediates); the
# build/*.py and build/*.sh SCRIPTS are files, not subdirs, so they stay tracked
/build/*/
*.spec.bak

# python
__pycache__/
*.py[cod]
.venv/
.venv-build/
venv/

# os
.DS_Store

# demo bundle (regenerated by build/make_demo_data.py)
/demo_data.zip

# NOTE: cbmi_pipelines/ and runtime_data/ ARE committed on purpose — they are
# the vendored, self-contained pipeline code + (encrypted) data that CI builds
# from. CI never needs the source *_CodeBase folders. Regenerate them with
# `python3 vendor.py --encrypt`. runtime_data holds CIPHERTEXT only (safe to commit).
